# Interlock dashboard public runtime config.
# Values prefixed with VITE_ are bundled into the browser build. Do not put secrets here.

VITE_INTERLOCK_API_URL=https://interlock.onrender.com

# Optional Supabase Auth browser login. Use a publishable key only; never use service_role in the browser.
# The backend should verify Supabase JWTs with OIDC_ISSUER, OIDC_AUDIENCE, OIDC_JWKS_URL, and an admin email/domain allowlist.
# VITE_SUPABASE_URL=https://project-ref.supabase.co
# VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_...
# VITE_SUPABASE_OAUTH_PROVIDER=google
# VITE_SUPABASE_REDIRECT_URI=https://your-dashboard.example/dashboard/auth/callback
# VITE_SUPABASE_CREATE_USER=false

# Optional generic OIDC browser SSO. Use a public SPA/OIDC client with Authorization Code + PKCE.
# The backend must also be configured with matching OIDC_ISSUER, OIDC_AUDIENCE, and OIDC_JWKS_URL.
# VITE_INTERLOCK_OIDC_ISSUER=https://idp.example.com/
# VITE_INTERLOCK_OIDC_AUTHORIZATION_URL=https://idp.example.com/oauth2/v1/authorize
# VITE_INTERLOCK_OIDC_TOKEN_URL=https://idp.example.com/oauth2/v1/token
# VITE_INTERLOCK_OIDC_CLIENT_ID=interlock-dashboard-spa
# VITE_INTERLOCK_OIDC_REDIRECT_URI=https://your-dashboard.example/dashboard/auth/callback
# VITE_INTERLOCK_OIDC_SCOPE=openid email profile
# VITE_INTERLOCK_OIDC_AUDIENCE=interlock-admin
# VITE_INTERLOCK_OIDC_LOGOUT_URL=https://idp.example.com/oauth2/v1/logout
