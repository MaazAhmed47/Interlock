{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "redirects": [
    {
      "source": "/",
      "has": [
        { "type": "host", "value": "www.getinterlock.dev" }
      ],
      "destination": "https://getinterlock.dev/",
      "statusCode": 301
    },
    {
      "source": "/:path*",
      "has": [
        { "type": "host", "value": "www.getinterlock.dev" }
      ],
      "destination": "https://getinterlock.dev/:path*",
      "statusCode": 301
    }
  ],
  "rewrites": [
    { "source": "/dashboard", "destination": "/dashboard/index.html" },
    { "source": "/dashboard/(.*)", "destination": "/dashboard/index.html" }
  ]
}
