# Copy this file to .env and fill only the platforms you want.

# Bluesky - free. Use an app password, not your main password.
BLUESKY_HANDLE=your-handle.bsky.social
BLUESKY_APP_PASSWORD=xxxx-xxxx-xxxx-xxxx

# Mastodon - free. Create an app/token on your Mastodon instance with write:statuses and write:media.
MASTODON_INSTANCE=https://mastodon.social
MASTODON_ACCESS_TOKEN=your-mastodon-token

# Reddit - free API, but subreddits may block bots or image posts.
REDDIT_CLIENT_ID=your-client-id
REDDIT_CLIENT_SECRET=your-client-secret
REDDIT_USERNAME=your-username
REDDIT_PASSWORD=your-password
REDDIT_USER_AGENT=social-poster/0.1 by u_your_username

# Daily automation
DAILY_PLATFORMS=x,bluesky,reddit
REDDIT_SUBREDDIT=YOUR_SUBREDDIT_WITHOUT_R_SLASH
